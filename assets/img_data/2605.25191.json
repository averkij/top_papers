        "header": "3Method",
        "images": [
            {
                "img": "https://arxiv.org/html/2605.25191/2605.25191v1/figures/methods/pipeline.png",
                "caption": "Figure 2:VCF pipeline overview. The pipeline integrates image guidance into text-conditioned diffusion models via three key components: (1) the Image Aligner maps image tokens to the text embedding space; (2) the Text–Image Fusion module combines aligned image and text tokens into fused representations; and (3) PNO (optional) refines the fused conditioning and initial noise to enhance visual alignment in the final output.",
                "position": 464
            }
        ]

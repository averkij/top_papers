        "header": "2Preliminaries",
        "images": [
            {
                "img": "https://arxiv.org/html/2603.14366/2603.14366v1/x2.png",
                "caption": "Figure 2:Overall Framework of PixelREPA.PixelREPA masks a subset of tokens in an intermediate diffusion feature map.\nThe full token sequence, with only a subset masked, are then transformed by a shallow Transformer adapter and aligned to features from a frozen pretrained semantic encoder.\nThis transforms the alignment target and reduces overfitting to the external semantic representation.",
                "position": 367
            }
        ]

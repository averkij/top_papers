        "header": "1Introduction",
        "images": [
            {
                "img": "https://arxiv.org/html/2606.14697/2606.14697v1/x1.png",
                "caption": "Figure 1:Different reasoning failures can produce the same wrong answer in medical VQA.\nIn this example, the correct answer is “fat”, but visual misrecognition, incorrect knowledge recall, and flawed reasoning integration can each lead the model to answer “abscess”.\nThis motivatesClinHallu, which diagnoses hallucinations by localizing them to specific reasoning stages rather than only judging final-answer correctness.",
                "position": 348
            }
        ]
    },

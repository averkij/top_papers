    {
        "header": "3Methods",
        "images": [
            {
                "img": "https://arxiv.org/html/2604.23600/2604.23600v1/x2.png",
                "caption": "Figure 2:A step-by-step illustration of our experimental pipeline. Persona-conditioned prompts specifying gender, occupation, and personality traits are used to generate artifacts from multipleLLMs.\nThe generated artifacts are embedded in a multilingual sentence space, and gender stereotype centroids are constructed from curated stereotype word lists.\nStory-level bias scores are computed based on cosine similarity to these centroids and used in the subsequent analysis.",
                "position": 547
            },
            {
                "img": "https://arxiv.org/html/2604.23600/2604.23600v1/x3.png",
                "caption": "Figure 3:Percentage of generated sentences leaning toward male stereotypes across models.\nBars compare baseline prompts (without personality) and persona-conditioned prompts (with personality), averaged across English and Hindi generations.\nSentences with bias score>0>0are counted as male-leaning.",
                "position": 808
            }
        ]
    },
    {
        "header": "4Results",
        "images": [
            {
                "img": "https://arxiv.org/html/2604.23600/2604.23600v1/x4.png",
                "caption": "Figure 4:Personality trait effects on story-level gender bias scores, where a positive score means male-stereotypical alignment. Dark Triad traits produce positive shifts; few HEXACO traits show negative shifts.",
                "position": 865
            },
            {
                "img": "https://arxiv.org/html/2604.23600/2604.23600v1/x5.png",
                "caption": "Figure 5:Gender coefficient effects on story-level bias scores relative to the neutral baseline. Male personas shift bias positively; female personas shift it negatively, with the male effect larger in absolute magnitude.",
                "position": 890
            },
            {
                "img": "https://arxiv.org/html/2604.23600/2604.23600v1/x6.png",
                "caption": "Figure 6:Gender stratified personality effects on bias scores. Male personas (blue): Dark Triad show stronger positive shifts. The amplification is more pronounced for male-gendered personas.",
                "position": 896
            },
            {
                "img": "https://arxiv.org/html/2604.23600/2604.23600v1/x7.png",
                "caption": "Figure 7:Language stratified personality effects. English (blue): Stronger positive bias shifts, esp. Dark Triad. English shows greater personality-driven male-stereotypical amplification.",
                "position": 917
            }
        ]

        "header": "3Stereo World Model",
        "images": [
            {
                "img": "https://arxiv.org/html/2603.17375/2603.17375v1/x3.png",
                "caption": "Figure 3:Illustration of StereoWorld. Given a pair of stereo images and a conditional camera trajectory, StereoWorld first encodes conditional and noisy video latents from different viewpoints and timesteps using a unified camera–frame RoPE representation. It then performs denoising through a DiT equipped with stereo attention, ultimately producing the final stereo video.",
                "position": 360
            }
        ]

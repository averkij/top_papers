            },
            {
                "img": "https://arxiv.org/html/2605.16909/2605.16909v1/fig3_statis.png",
                "caption": "Figure 3:Distribution of tools, task difficulty, and task scenarios in TOBench.\nLeft: the number of calls for each tool, showing a long-tailed tool-usage distribution.\nMiddle: the distribution of task difficulty levels.\nRight: the scenario distribution of tasks across two high-level categories, Custom Service and Intelligent Creation.",
                "position": 692
            }
        ]
